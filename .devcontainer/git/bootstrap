#!/usr/bin/env bash
set -e

# Suppress cache hardlink warnings on bind-mounted filesystems
export UV_LINK_MODE=copy

echo "========================================================="
echo "  Bootstrapping SMLIGHT SMHUB Add-on (Production Git)... "
echo "========================================================="

# Ensure current user has write permissions to /opt/venv
if [ -d "/opt/venv" ]; then
    echo "Ensuring /opt/venv permissions are set correctly..."
    if command -v sudo &> /dev/null; then
        sudo chown -R $(whoami):$(whoami) /opt/venv
    else
        chown -R $(whoami):$(whoami) /opt/venv || true
    fi
fi

# Ensure current user has write permissions to ~/.platformio
PLATFORMIO_DIR="${HOME}/.platformio"
if [ -d "$PLATFORMIO_DIR" ]; then
    echo "Ensuring $PLATFORMIO_DIR permissions are set correctly..."
    if command -v sudo &> /dev/null; then
        sudo chown -R $(whoami):$(whoami) "$PLATFORMIO_DIR"
    else
        chown -R $(whoami):$(whoami) "$PLATFORMIO_DIR" || true
    fi
fi

echo "Installing production dependencies..."
uv pip install -r requirements.txt

echo "========================================================="
echo "  DevContainer Bootstrapped!                             "
echo "  Run 'esphome' command directly in your terminal.        "
echo "========================================================="
