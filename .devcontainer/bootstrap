#!/usr/bin/env bash
set -e

echo "========================================================="
echo "  Bootstrapping SMLIGHT SMHUB Add-on Environment...      "
echo "========================================================="

# Ensure current user has write permissions to /opt/venv
if [ -d "/opt/venv" ]; then
    echo "Ensuring /opt/venv permissions are set correctly..."
    if command -v sudo &> /dev/null; then
        sudo chown -R $(whoami):$(whoami) /opt/venv
    else
        chown -R $(whoami):$(whoami) /opt/venv || true
    fi
fi

echo "Initializing and updating git submodules..."
git submodule update --init --recursive

echo "========================================================="
echo "  DevContainer Bootstrapped!                             "
echo "========================================================="
